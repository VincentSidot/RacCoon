#!/usr/bin/env bash
set -euo pipefail

msg_file="${1:?missing commit message file}"
subject="$(grep -m1 -v '^[[:space:]]*#' "$msg_file" | tr -d '\r' || true)"
pattern='^\[([A-Z][A-Z0-9_-]*)\] .+'

if [[ -z "$subject" ]] || ! [[ "$subject" =~ $pattern ]]; then
    cat >&2 <<'EOF'
Invalid commit message.
Expected format: [ACTION] <message>
Examples:
  [ADD] keyboard driver
  [FIX] ring buffer wraparound
  [WIP] bootloader refactor
EOF
    exit 1
fi

action="${BASH_REMATCH[1]}"

if [[ "$action" == "WIP" ]]; then
    echo "WIP commit detected; skipping zig checks."
    exit 0
fi

# The kernel build toolchain (objcopy, fasm, GNU stat) only exists in the
# Linux build image, so on macOS we route `zig` through the docker wrapper.
# On Linux we use the native toolchain directly.
repo_root="$(git rev-parse --show-toplevel)"
if [[ "$(uname -s)" == "Darwin" ]]; then
    zig() { "$repo_root/scripts/zig.sh" "$@"; }
fi

echo "Running zig build lint"
zig build lint

echo "Running zig build"
zig build

echo "Running zig build test"
zig build test
