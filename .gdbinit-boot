set pagination off
set confirm off
set disassembly-flavor intel

target remote localhost:1234

define boot16
    set architecture i8086
    set disassembly-flavor intel
end

define pm32
    set architecture i386
    set disassembly-flavor intel
end

define regs16
    info registers ax bx cx dx si di sp bp cs ds es ss ip eflags
end

define regs32
    info registers eax ebx ecx edx esi edi esp ebp eip eflags cs ds es ss
end

define xip16
    x/16i (($cs << 4) + $ip)
end

define xip32
    x/16i $eip
end

boot16
hb *0x7c00
hb *0x8000
c
